generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider  = "mysql"
    url       = env("DATABASE_URL")
}

enum Permissao {
    DEV
    ADM
    USR
}

enum TipoUsuario {
    INTERNO
    EXTERNO
}

model Usuario {
    id                     String                 @id @default(uuid())
    tipo                   TipoUsuario            @default(INTERNO)
    nome                   String
    email                  String                 @unique
    // Campos exclusivos de usuários INTERNO (administrativos)
    login                  String?                @unique
    permissao              Permissao?
    avatar                 String?
    status                 Boolean                @default(true)
    // Campos de autenticação (EXTERNO usa senha, INTERNO usa LDAP)
    senha                  String?
    primeiroAcesso         Boolean                @default(true)
    criadoEm               DateTime               @default(now())
    atualizadoEm           DateTime               @default(now()) @updatedAt

    eleitor                Eleitor?
    candidatura            Candidatura?

    @@map("usuarios")
}

enum Status {
    EM_ANALISE
    DEFERIDO
    INDEFERIDO
}

enum TipoInscricao {
    MORADOR
    TRABALHADOR
    REP_MORADIA
    REP_ONGS
    REP_PROFISSIONAIS
    REP_EMPRESARIAIS
}

enum TipoCandidato {
    INDIVIDUAL
    TITULAR
    SUPLENTE
}

enum Genero {
    MASCULINO
    FEMININO
    OUTRO
}

enum TipoCadastro {
    ELEITOR
    CANDIDATO
}

enum CategoriaArquivo {
    REQUERIMENTO
    DOCUMENTO_IDENTIDADE
    CPF
    TITULO_ELEITOR
    COMPROVANTE_RESIDENCIA
    COMPROVANTE_TRABALHO
    FOTO
    DECLARACAO
    DECLARACAO_ATUACAO
    ESTATUTO_SOCIAL
    ATA_ELEICAO
    CERTIDAO_CNPJ
    OUTRO
}

enum AreaPerimetro {
    ADESAO
    EXPANDIDO
    NAO_APLICA
}

model Candidatura {
    id                     String                 @id @default(uuid())
    tipoCadastro           TipoCadastro           @default(ELEITOR)
    tipoInscricao          TipoInscricao          @default(MORADOR)
    usuarioId              String                 @unique
    status                 Status                 @default(EM_ANALISE)

    criadoEm               DateTime               @default(now())
    atualizadoEm           DateTime               @default(now()) @updatedAt

    usuario                Usuario                @relation(fields: [usuarioId], references: [id])
    candidatos             Candidato[]
    organizacao            Organizacao?
    arquivos               Arquivo[]
    endereco               Endereco?

    @@map("inscricoes")
}

model Arquivo {
    id                     String                  @id @default(uuid())
    nome                   String
    tipo                   String
    tamanho                Int
    caminho                String
    candidaturaId          String?
    candidatoId            String?
    organizacaoId          String?
    eleitorId              String?
    categoria              CategoriaArquivo

    criadoEm               DateTime                @default(now())
    atualizadoEm           DateTime                @default(now()) @updatedAt

    candidatura            Candidatura?            @relation(fields: [candidaturaId], references: [id])
    candidato              Candidato?              @relation(fields: [candidatoId], references: [id])
    organizacao            Organizacao?            @relation(fields: [organizacaoId], references: [id])
    eleitor                Eleitor?                @relation(fields: [eleitorId], references: [id])

    @@map("arquivos")
}

model Endereco {
    id                     String                 @id @default(uuid())
    logradouro             String
    numero                 String?
    complemento            String?
    bairro                 String
    cidade                 String
    estado                 String
    cep                    String
    latitude               Float?
    longitude              Float?
    areaPerimetro          AreaPerimetro          @default(NAO_APLICA)
    candidaturaId          String                 @unique

    criadoEm               DateTime               @default(now())
    atualizadoEm           DateTime               @default(now()) @updatedAt

    candidatura            Candidatura            @relation(fields: [candidaturaId], references: [id])

    @@map("enderecos")
}

model Organizacao {
    id                     String                 @id @default(uuid())
    cnpj                   String                 @unique
    razaoSocial            String
    candidaturaId          String                 @unique

    criadoEm               DateTime               @default(now())
    atualizadoEm           DateTime               @default(now()) @updatedAt

    candidatura            Candidatura            @relation(fields: [candidaturaId], references: [id])
    arquivos               Arquivo[]

    @@map("organizacoes")
}

model Candidato {
    id                     String                 @id @default(uuid())
    nome                   String
    nomeEmpresa            String?
    nomeSocial             String?
    email                  String
    telefone               String?
    cpf                    String                 @unique
    dataNascimento         DateTime               @db.Date
    genero                 Genero
    tipoCandidato          TipoCandidato          @default(INDIVIDUAL)
    candidaturaId          String

    criadoEm               DateTime               @default(now())
    atualizadoEm           DateTime               @default(now()) @updatedAt
    
    candidatura            Candidatura            @relation(fields: [candidaturaId], references: [id])
    arquivos               Arquivo[]

    @@map("representantes")
}

model Eleitor {
    id                     String                 @id @default(uuid())
    nome                   String
    email                  String
    telefone               String?
    cpf                    String                 @unique
    dataNascimento         DateTime               @db.Date
    genero                 Genero
    tituloEleitor          String?                @unique
    usuarioId              String?                @unique

    criadoEm               DateTime               @default(now())
    atualizadoEm           DateTime               @default(now()) @updatedAt

    usuario                Usuario?               @relation(fields: [usuarioId], references: [id])
    arquivos               Arquivo[]

    @@map("eleitores")
}