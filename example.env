NEXT_PUBLIC_PROJECT_NAME="OUCAB 2026"
NEXT_PUBLIC_API_URL=http://localhost:3005/oucab/

# Banco de dados MySQL do servidor (acessado via host.docker.internal dentro do container)
# Em produção: mysql://usuario:senha@host.docker.internal:3306/nome_do_banco
# Em dev local: mysql://usuario:senha@localhost:3306/nome_do_banco
DATABASE_URL=mysql://usuario:senha@host.docker.internal:3306/oucab2026

# NextAuth configuration
AUTH_SECRET=
# NEXTAUTH_URL deve incluir o basePath /oucab
NEXTAUTH_URL=https://smuleleicoes.prefeitura.sp.gov.br/oucab

# Serviço externo de autenticação (LDAP/AD)
# Em Docker no CentOS: http://host.docker.internal:3006/
AUTH_SERVER=http://host.docker.internal:3006/

# "local" ignora o AUTH_SERVER e valida só pelo banco local
ENVIRONMENT=local